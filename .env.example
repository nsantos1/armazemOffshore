# ---------------------------------------------------------------------------
# Envio do formulário de contato (API Route /api/contact)
# Copie este arquivo para `.env.local` (desenvolvimento) e configure as mesmas
# variáveis no painel da Vercel (Project > Settings > Environment Variables).
#
# Usamos o servidor de e-mail PRÓPRIO da Armazém Offshore (não mais o Resend).
#
# IMAP x SMTP:
#   - IMAP é o protocolo de LEITURA da caixa de entrada (receber/consultar).
#   - O ENVIO de e-mails (o que o formulário faz) usa SMTP.
#   As credenciais de acesso (host/usuário/senha) normalmente são as mesmas do
#   provedor de hospedagem de e-mail, mudando apenas host/porta por protocolo.
# ---------------------------------------------------------------------------

# O mesmo SMTP é usado por: formulário de contato (/api/contact) e
# disparo de campanhas de newsletter (/api/newsletter/send).
#
# ---- SMTP (ENVIO) ---------------------------------------------------------
# Host do servidor de saída (ex.: mail.armazemoffshore.com.br / smtp.hostinger.com)
MAIL_SMTP_HOST=
# Porta SMTP: 465 (SSL) ou 587 (STARTTLS). Default: 587
MAIL_SMTP_PORT=587
# "true" quando usar a porta 465 (SSL direto); "false" para 587 (STARTTLS)
MAIL_SMTP_SECURE=false

# Conta de e-mail e senha (as mesmas usadas no IMAP)
MAIL_USER=contato@armazemoffshore.com.br
MAIL_PASS=

# ---- IMAP (LEITURA — reservado para uso futuro) ---------------------------
# Não é usado pelo formulário de contato (envio é SMTP), mas fica documentado
# aqui porque as credenciais são as mesmas e podem ser reaproveitadas.
MAIL_IMAP_HOST=
MAIL_IMAP_PORT=993
MAIL_IMAP_SECURE=true

# ---- Remetente / destinatário -----------------------------------------------
# Nome de exibição do remetente (aparece como "Nome <email>"). Opcional.
MAIL_FROM_NAME=Armazém Offshore
# Remetente exibido no e-mail. Default: o valor de MAIL_USER.
CONTACT_FROM_EMAIL=contato@armazemoffshore.com.br
# Destinatário dos leads do formulário + Reply-To das newsletters.
CONTACT_TO_EMAIL=contato@armazemoffshore.com.br
# Para quem vão as solicitações de "Esqueci minha senha" do painel admin.
# Opcional — default: CONTACT_TO_EMAIL.
PASSWORD_RESET_TO=marketing@armazemoffshore.com.br

# ---- Banco de dados: Turso / libSQL (ver src/lib/db.ts) --------------------
# Turso É SQLite na nuvem. O mesmo cliente atende local e produção:
#   - Sem TURSO_DATABASE_URL  → modo ARQUIVO local (file:./data/app.db). Dev.
#   - Com TURSO_DATABASE_URL  → banco Turso na nuvem. Produção (funciona no Vercel).
# Drivers: "turso" (padrão) ou "memory" (placeholder que NÃO persiste).
DB_DRIVER=turso
# Produção — dados da base Turso (crie grátis em turso.tech):
# TURSO_DATABASE_URL=libsql://sua-base.turso.io
# TURSO_AUTH_TOKEN=seu-token-de-acesso

# Chave de ESCRITA do admin — protege as APIs que criam/editam conteúdo
# (ex.: notícias em /api/admin/posts). OBRIGATÓRIA para publicar posts.
# Gere um valor aleatório:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# ATENÇÃO: por ser NEXT_PUBLIC, fica visível no bundle — é uma barreira contra
# escrita anônima, NÃO segurança real. A proteção definitiva é a FASE 2
# (sessão de servidor). Ao alterar, refaça o build.
NEXT_PUBLIC_ADMIN_API_KEY=
